# NophiGene local environment example.
# Copy this file to `.env` and fill in only the values you have.
# `.env` is ignored by git and is loaded when the app starts through `src/app.py`.
#
# Do not commit real API keys, passwords, licensed database exports, or private paths.
# UI-entered Knowledge Source credentials are stored only in server memory for the
# current browser session; they are not written to Flask cookies, reports, cache,
# job manifests, or dynamic KB JSON.


# ---------------------------------------------------------------------------
# App runtime
# ---------------------------------------------------------------------------

# Use a long random value for non-local deployments.
NOPHIGENE_SECRET_KEY=replace-with-a-long-random-string

# INFO is recommended for normal local use. Use DEBUG only while troubleshooting.
NOPHIGENE_LOG_LEVEL=INFO

# Local BAM/VCF extraction is intentionally opt-in outside Docker.
# The launcher can also set this automatically after checking required tools.
NOPHIGENE_ENABLE_LOCAL_EXTRACTION=0


# ---------------------------------------------------------------------------
# TLS and NCBI E-utilities
# ---------------------------------------------------------------------------

# Optional custom CA bundle for corporate/proxy networks. Leave blank for the
# app's default certifi + Windows certificate-store bundle.
NOPHIGENE_CA_BUNDLE=

# Alternative CA variables also honored by the request client.
REQUESTS_CA_BUNDLE=
SSL_CERT_FILE=

# Recommended by NCBI for E-utilities requests.
NOPHIGENE_NCBI_TOOL=NophiGeneDynamicKB
NOPHIGENE_NCBI_EMAIL=your.email@example.org

# Optional NCBI API key for higher E-utilities rate limits.
NOPHIGENE_NCBI_API_KEY=
# Alternative name supported by NCBI tooling and also honored by NophiGene.
NCBI_API_KEY=


# ---------------------------------------------------------------------------
# Knowledge Source official API tokens
# ---------------------------------------------------------------------------

# OMIM API token.
NOPHIGENE_SOURCE_OMIM_TOKEN=

# DISGENET API token.
NOPHIGENE_SOURCE_DISGENET_TOKEN=

# GeneCards licensed/official API token, if your license provides one.
NOPHIGENE_SOURCE_GENECARDS_TOKEN=

# OncoKB API token.
NOPHIGENE_SOURCE_ONCOKB_TOKEN=

# CORE API token.
NOPHIGENE_SOURCE_CORE_TOKEN=

# VarSome API token, if your license provides one.
NOPHIGENE_SOURCE_VARSOME_TOKEN=

# DrugBank API token, if your license provides one.
# DrugBank may still require permitted user exports for some workflows.
NOPHIGENE_SOURCE_DRUGBANK_TOKEN=


# ---------------------------------------------------------------------------
# Licensed/import-only sources
# ---------------------------------------------------------------------------

# These sources currently do not have a configured token variable in the app.
# Use the Knowledge Sources tab to upload legally obtained CSV/JSON exports, or
# leave them selected so the dynamic KB records linkout/status-only metadata:
#
# - HGMD
# - Embase
# - Scopus
# - Web of Science
# - Google Scholar
# - Mastermind
# - Franklin by Genoox
#
# No scraping, login automation, CAPTCHA bypassing, or paywall extraction is
# performed for these sources.
